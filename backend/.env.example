PORT=4001
NODE_ENV=development
JWT_SECRET=replace_with_a_long_random_string

DATABASE_URL="postgresql://youruser@localhost:5432/resume_builder_ai"

# AI (Groq API) - powers summary generation, bullet point rewriting,
# interview question generation, and job-match scoring
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# Optional: defaults to llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# Razorpay - ₹499/year subscription
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_ID_ANNUAL_499=plan_xxxxxxxxxxxx

# SMS OTP provider for phone login (MSG91 is commonly used in India;
# Twilio also works with light changes to otp.service.js).
# If left blank, OTPs are just printed to the server console in dev mode
# so you can test the flow without paying for SMS credits.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
